{
  "name": "viridi",
  "version": "1.0.0",
  "description": "Vietnam price alert system for gasoline and gold",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check:gas": "node dist/jobs/checkGas.js",
    "check:gold": "node dist/jobs/checkGold.js",
    "check:summary": "node dist/jobs/dailySummary.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "vietnam",
    "price",
    "gasoline",
    "gold",
    "alerts",
    "monitor"
  ],
  "author": "",
  "license": "GPL-3.0-only",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "resend": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
